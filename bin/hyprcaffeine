#!/usr/bin/env bash
# HyprCaffeine — Idle inhibition utility for Hyprland
# Version: 0.7.4
# Author: HyprCaffeine Contributors
# License: MIT

set -uo pipefail

# ── Path Resolution ──────────────────────────────────────────────────────────
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# Dev: scripts/ sibling of bin/ | Install: ~/.local/share/hyprcaffeine/scripts/
if [[ -d "${SCRIPT_DIR}/../scripts" ]]; then
    LIB_DIR="${SCRIPT_DIR}/../scripts"
elif [[ -d "${SCRIPT_DIR}/../share/hyprcaffeine/scripts" ]]; then
    LIB_DIR="${SCRIPT_DIR}/../share/hyprcaffeine/scripts"
else
    echo "Error: scripts/ not found" >&2; exit 1
fi

# ── Version ──────────────────────────────────────────────────────────────────
readonly VERSION="0.7.4"
readonly APP_NAME="HyprCaffeine"

# ── Dry Run Mode ─────────────────────────────────────────────────────────────
DRY_RUN=false
[[ "${1:-}" == "--dry-run" ]] && { DRY_RUN=true; shift; }

# ── Catppuccin Mocha Palette ─────────────────────────────────────────────────
readonly CLR_TEXT="#cdd6f4"
readonly CLR_SURFACE="#1e1e2e"
readonly CLR_BLUE="#89b4fa"
readonly CLR_GREEN="#a6e3a1"
readonly CLR_RED="#f38ba8"
readonly CLR_YELLOW="#f9e2af"

# ── Nerd Font Icons (from icons.sh — verified via nerdfonts.com cheat-sheet) ──
source "${LIB_DIR}/icons.sh"
readonly ICON_ACTIVE="${NF_COFFEE}"
readonly ICON_INACTIVE="${NF_COFFEE_OUTLINE}"
readonly ICON_TIMER="${NF_TIMER}"
readonly ICON_INFINITE="${NF_INFINITE}"
readonly ICON_MONITOR="${NF_MONITOR}"
readonly ICON_LID="${NF_LAPTOP}"
# Waybar uses same NF icons as menu — consistent UI
readonly WB_COFFEE="${NF_COFFEE}"
readonly WB_COFFEE_OFF="${NF_COFFEE_OUTLINE}"
readonly WB_LOOP="${NF_INFINITE}"
readonly WB_TIMER="${NF_TIMER}"
readonly WB_MONITOR="${NF_MONITOR}"
readonly WB_LID="${NF_LAPTOP}"
# ── State Directory ──────────────────────────────────────────────────────────
readonly STATE_DIR="${HOME}/.cache/hyprcaffeine"
readonly STATE_FILE="${STATE_DIR}/state.json"

# ── Source Libraries ─────────────────────────────────────────────────────────
source "${LIB_DIR}/config.sh"
source "${LIB_DIR}/state.sh"
source "${LIB_DIR}/timer.sh"
source "${LIB_DIR}/notify.sh"
source "${LIB_DIR}/hyprland.sh"
source "${LIB_DIR}/watcher.sh"
source "${LIB_DIR}/keybinds.sh"

# ── Helpers ──────────────────────────────────────────────────────────────────

show_help() {
    cat <<EOF
${APP_NAME} v${VERSION} — Independent idle-inhibition features for Hyprland

USAGE:
    hyprcaffeine [SUBCOMMAND] [OPTIONS]

FEATURES (each independent):
    Timer/Infinite      Blocks SUSPEND only (not dim/dpms/lock)
    Keep Display On     Blocks dim + DPMS + lock (persistent across reboots)
    Block Lid           Blocks lid-close suspend (persistent across reboots)

SUBCOMMANDS:
    (none)              Show interactive menu
    on [DURATION]       Activate sleep inhibition (suspend blocker)
    off                 Deactivate sleep inhibition only
    off --all           Deactivate all features (sleep + monitor + lid)
    status              Show current state
    toggle              Toggle sleep inhibition on/off
    waybar              Output Waybar-compatible JSON status
    menu                Walker/wofi launcher menu
    monitor on|off|toggle  Keep Display On (blocks dim + DPMS)
    lid on|off|toggle      Block lid-close suspend
    waybar-setup [--force]  Configure waybar integration (smart)
    waybar-remove       Remove waybar integration
    keybinds install|remove|status  Manage Hyprland keybindings
    watcher start|stop|status  Auto-activate daemon

DURATION FORMATS:
    30s, 15m, 2h, 1:30 (HH:MM), infinite, bare number = minutes

EXAMPLES:
    hyprcaffeine on 30m            # Block suspend for 30 minutes
    hyprcaffeine on 1:30           # Block suspend for 1h 30min
    hyprcaffeine on infinite       # Block suspend forever
    hyprcaffeine off               # Stop sleep inhibition
    hyprcaffeine monitor toggle    # Toggle display keep-awake
    hyprcaffeine lid on            # Enable lid-close inhibit
    hyprcaffeine status            # Show all states
EOF
}

show_version() {
    echo "${APP_NAME} v${VERSION}"
}

# ── Parse duration string to seconds ────────────────────────────────────────
parse_duration() {
    local duration="${1:-infinite}"
    case "${duration}" in
        infinite|inf) echo "0" ;;
        *s) echo "${duration%s}" ;;
        *m) echo "$(( ${duration%m} * 60 ))" ;;
        *h) echo "$(( ${duration%h} * 3600 ))" ;;
        *)
            # HH:MM format (e.g. 1:30 = 90 minutes = 5400 seconds)
            if [[ "${duration}" =~ ^([0-9]+):([0-9]{2})$ ]]; then
                local hours="${BASH_REMATCH[1]}"
                local minutes="${BASH_REMATCH[2]}"
                echo "$(( hours * 3600 + minutes * 60 ))"
            elif [[ "${duration}" =~ ^[0-9]+$ ]]; then
                echo "$(( duration * 60 ))"
            else
                echo "-1"
            fi
            ;;
    esac
}

# ── Core Actions ─────────────────────────────────────────────────────────────

# Activate idle inhibition (ONLY idle — monitor/lid are independent)
do_on() {
    local duration="${1:-}"
    
    # Use config default if no duration specified
    if [[ -z "${duration}" ]]; then
        local config_default
        config_default="$(config_get timeouts.default)"
        if [[ -n "${config_default}" ]]; then
            # Config value is in seconds; convert to minutes string for parse_duration
            local minutes=$(( config_default / 60 ))
            if [[ "${minutes}" -gt 0 ]]; then
                duration="${minutes}m"
            else
                duration="${config_default}s"
            fi
        else
            duration="infinite"
        fi
    fi

    local duration_seconds
    duration_seconds="$(parse_duration "${duration}")"

    if [[ "${duration_seconds}" -eq -1 ]]; then
        notify_error "Invalid duration: ${duration}"
        echo "Error: Invalid duration '${duration}'." >&2
        exit 1
    fi

    # Activate idle inhibitor
    if [[ "${DRY_RUN}" == true ]]; then
        echo "[dry-run] idle inhibitor ON"
    else
        hypr_idle_inhibit_on || {
            echo "Warning: Could not reach Hyprland — state saved anyway." >&2
        }
    fi

    # Preserve current monitor/lid state
    local monitor_val lid_val
    monitor_val="$(state_get_monitor)"
    lid_val="$(state_get_lid)"

    state_save "active" "${duration_seconds}" "" "${monitor_val}" "${lid_val}"
    timer_start "${duration_seconds}"

    local human_duration
    if [[ "${duration_seconds}" -eq 0 ]]; then
        human_duration=" infinite"
    else
        human_duration="$(timer_human "${duration_seconds}")"
    fi

    notify_send "${ICON_ACTIVE} Caffeine Active" "Sleep inhibition: ${human_duration}"
    echo "${ICON_ACTIVE} Caffeine activated — duration: ${human_duration}"
}

# Deactivate idle inhibition (ONLY idle — monitor/lid stay as they are)
do_off() {
    local all="${1:-}"

    timer_stop

    if [[ "${DRY_RUN}" == true ]]; then
        echo "[dry-run] idle inhibitor OFF"
    else
        hypr_idle_inhibit_off
    fi

    if [[ "${all}" == "--all" ]]; then
        do_monitor_off
        do_lid_off
        state_save "inactive" "0" "" "false" "false"
        notify_send "${ICON_INACTIVE} Caffeine Off" "All features disabled"
        echo "${ICON_INACTIVE} All features deactivated"
    else
        # Preserve monitor/lid
        local monitor_val lid_val
        monitor_val="$(state_get_monitor)"
        lid_val="$(state_get_lid)"
        state_save "inactive" "0" "" "${monitor_val}" "${lid_val}"
        notify_send "${ICON_INACTIVE} Caffeine Off" "Idle inhibition disabled"
        echo "${ICON_INACTIVE} Idle inhibition deactivated"
    fi
}

# Toggle idle inhibition
do_toggle() {
    local state
    state="$(state_get_status)"
    if [[ "${state}" == "active" ]]; then
        do_off
    else
        do_on "infinite"
    fi
}

# ── Monitor (independent toggle) ────────────────────────────────────────────

do_monitor_on() {
    if [[ "${DRY_RUN}" == true ]]; then
        echo "[dry-run] monitor keep-awake ON"
        return
    fi
    hypr_monitor_on || {
        echo "Warning: Monitor control failed." >&2
        return 1
    }
    state_set_monitor "true"
    echo "${ICON_MONITOR} Monitor keep-awake: ON"
    notify_send "${ICON_MONITOR} Monitor" "Keep display on: enabled"
}

do_monitor_off() {
    if [[ "${DRY_RUN}" == true ]]; then
        echo "[dry-run] monitor keep-awake OFF"
        return
    fi
    hypr_monitor_off
    state_set_monitor "false"
    echo "${ICON_MONITOR} Monitor keep-awake: OFF"
    notify_send "${ICON_MONITOR} Monitor" "Keep display on: disabled"
}

do_monitor_toggle() {
    local current
    current="$(state_get_monitor)"
    if [[ "${current}" == "true" ]]; then
        do_monitor_off
    else
        do_monitor_on
    fi
}

# ── Lid (independent toggle) ────────────────────────────────────────────────

do_lid_on() {
    if [[ "${DRY_RUN}" == true ]]; then
        echo "[dry-run] lid inhibit ON"
        return
    fi
    lid_inhibit_start || {
        echo "Warning: Lid inhibition failed." >&2
        return 1
    }
    state_set_lid "true"
    echo "${ICON_LID} Lid-close inhibit: ON"
    notify_send "${ICON_LID} Lid" "Lid-close inhibit: enabled"
}

do_lid_off() {
    if [[ "${DRY_RUN}" == true ]]; then
        echo "[dry-run] lid inhibit OFF"
        return
    fi
    lid_inhibit_stop
    state_set_lid "false"
    echo "${ICON_LID} Lid-close inhibit: OFF"
    notify_send "${ICON_LID} Lid" "Lid-close inhibit: disabled"
}

do_lid_toggle() {
    local current
    current="$(state_get_lid)"
    if [[ "${current}" == "true" ]]; then
        do_lid_off
    else
        do_lid_on
    fi
}

# ── Status ───────────────────────────────────────────────────────────────────

do_status() {
    local state monitor lid parts=()

    state="$(state_get_status)"
    monitor="$(state_get_monitor)"
    lid="$(state_get_lid)"

    # Idle status
    if [[ "${state}" == "active" ]]; then
        local duration remaining
        duration="$(state_get_duration)"
        remaining="$(state_get_remaining)"

        if [[ "${duration}" == "0" ]]; then
            parts+=("${ICON_ACTIVE} Idle: ${ICON_INFINITE} infinite")
        else
            parts+=("${ICON_ACTIVE} Idle: ${remaining}")
        fi
    else
        parts+=("${ICON_INACTIVE} Idle: off")
    fi

    # Monitor
    if [[ "${monitor}" == "true" ]]; then
        parts+=("${ICON_MONITOR} Monitor: ON")
    else
        parts+=("${ICON_MONITOR} Monitor: off")
    fi

    # Lid
    if [[ "${lid}" == "true" ]]; then
        parts+=("${ICON_LID} Lid: ON")
    else
        parts+=("${ICON_LID} Lid: off")
    fi

    echo "$(IFS=$' · '; echo "${parts[*]}")"
}

# ── Waybar ───────────────────────────────────────────────────────────────────

do_waybar() {
    local state monitor lid duration
    local timer_on="false" infinite_on="false"

    state="$(state_get_status)"
    monitor="$(state_get_monitor)"
    lid="$(state_get_lid)"
    duration="$(state_get_duration)"

    if [[ "${state}" == "active" ]]; then
        if [[ "${duration}" -eq 0 ]]; then
            infinite_on="true"
        else
            timer_on="true"
        fi
    fi

    # ── Build text ── cup first, then active toggle icons
    # Cup: filled when idle active, outline when off
    local idle_active="false"
    [[ "${timer_on}" == "true" || "${infinite_on}" == "true" ]] && idle_active="true"

    local cup="${WB_COFFEE_OFF}"
    [[ "${idle_active}" == "true" ]] && cup="${WB_COFFEE}"

    local action_parts=()
    if [[ "${infinite_on}" == "true" ]]; then
        action_parts+=("${WB_LOOP}")
    fi
    if [[ "${timer_on}" == "true" ]]; then
        action_parts+=("${WB_TIMER} $(state_get_remaining)")
    fi
    if [[ "${monitor}" == "true" ]]; then
        action_parts+=("${WB_MONITOR}")
    fi
    if [[ "${lid}" == "true" ]]; then
        action_parts+=("${WB_LID}")
    fi

    local text="${cup}"
    if [[ ${#action_parts[@]} -gt 0 ]]; then
        text="${cup} $(IFS=' '; echo "${action_parts[*]}")"
    fi

    # ── Build tooltip ──
    local tooltip_parts=()
    if [[ "${timer_on}" == "true" ]]; then
        tooltip_parts+=("${NF_TIMER} Timer: $(state_get_remaining)")
    fi
    if [[ "${infinite_on}" == "true" ]]; then
        tooltip_parts+=("${NF_INFINITE} Infinite mode")
    fi
    if [[ "${monitor}" == "true" ]]; then
        tooltip_parts+=("${NF_MONITOR} Display: ON")
    fi
    if [[ "${lid}" == "true" ]]; then
        tooltip_parts+=("${NF_LAPTOP} Lid: Blocked")
    fi

    local tooltip
    if [[ ${#tooltip_parts[@]} -eq 0 ]]; then
        tooltip="☕ Caffeine: Inactive"
    else
        tooltip="$(IFS=' | '; echo "${tooltip_parts[*]}")"
    fi

    # ── CSS class + color based on toggle combination ──
    local class="hc-off"
    local color="#6c7086"

    if [[ "${infinite_on}" == "true" && "${monitor}" == "true" && "${lid}" == "true" ]]; then
        class="hc-all"; color="#f38ba8"
    elif [[ "${timer_on}" == "true" && "${monitor}" == "true" && "${lid}" == "true" ]]; then
        class="hc-all"; color="#f38ba8"
    elif [[ "${infinite_on}" == "true" && "${monitor}" == "true" ]]; then
        class="hc-infinite-monitor"; color="#a6e3a1"
    elif [[ "${infinite_on}" == "true" && "${lid}" == "true" ]]; then
        class="hc-infinite-lid"; color="#f5c2e7"
    elif [[ "${timer_on}" == "true" && "${monitor}" == "true" ]]; then
        class="hc-timer-monitor"; color="#a6e3a1"
    elif [[ "${timer_on}" == "true" && "${lid}" == "true" ]]; then
        class="hc-timer-lid"; color="#f5c2e7"
    elif [[ "${monitor}" == "true" && "${lid}" == "true" ]]; then
        class="hc-monitor-lid"; color="#89b4fa"
    elif [[ "${infinite_on}" == "true" ]]; then
        class="hc-infinite"; color="#fab387"
    elif [[ "${timer_on}" == "true" ]]; then
        class="hc-timer"; color="#fab387"
    elif [[ "${monitor}" == "true" ]]; then
        class="hc-monitor"; color="#94e2d5"
    elif [[ "${lid}" == "true" ]]; then
        class="hc-lid"; color="#cba6f7"
    fi

    tooltip="$(echo "${tooltip}" | sed 's/\\/\\\\/g; s/"/\\"/g')"

    printf '{"text":"%s","tooltip":"%s","class":"%s","color":"%s"}\n' \
        "${text}" "${tooltip}" "${class}" "${color}"
}

# ── Waybar (via ui-engine.sh) ──────────────────────────────────────────────

do_waybar_engine() {
    bash "${LIB_DIR}/ui-engine.sh" waybar
}

# ── Main Entry Point ─────────────────────────────────────────────────────────

main() {
    mkdir -p "${STATE_DIR}"

    local subcommand="${1:-}"
    shift 2>/dev/null || true

    case "${subcommand}" in
        --help|-h)
            show_help
            ;;
        --version|-v)
            show_version
            ;;
        on)
            do_on "${1:-}"
            ;;
        off)
            do_off "${1:-}"
            ;;
        status)
            do_status
            ;;
        toggle)
            do_toggle
            ;;
        waybar)
            do_waybar
            ;;
        menu)
            # Launch menu via hyprctl so it gets proper Wayland context
            if command -v hyprctl &>/dev/null && [[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]]; then
                hyprctl dispatch exec "bash '${LIB_DIR}/caffeine-menu.sh'" 2>/dev/null
            else
                bash "${LIB_DIR}/caffeine-menu.sh"
            fi
            ;;
        waybar-setup)
            bash "${LIB_DIR}/waybar-setup.sh" "${1:-}"
            ;;
        waybar-remove)
            bash "${LIB_DIR}/waybar-remove.sh"
            ;;
        monitor)
            local action="${1:-toggle}"
            case "${action}" in
                on)     do_monitor_on ;;
                off)    do_monitor_off ;;
                toggle) do_monitor_toggle ;;
                *)      echo "Usage: hyprcaffeine monitor <on|off|toggle>" >&2; exit 1 ;;
            esac
            ;;
        lid)
            local action="${1:-toggle}"
            case "${action}" in
                on)     do_lid_on ;;
                off)    do_lid_off ;;
                toggle) do_lid_toggle ;;
                *)      echo "Usage: hyprcaffeine lid <on|off|toggle>" >&2; exit 1 ;;
            esac
            ;;
        keybinds)
            local kb_action="${1:-status}"
            case "${kb_action}" in
                install) _kb_install ;;
                remove)  _kb_remove ;;
                status)  _kb_status ;;
                *)       echo "Usage: hyprcaffeine keybinds <install|remove|status>" >&2; exit 1 ;;
            esac
            ;;
        watcher)
            local watcher_action="${1:-}"
            case "${watcher_action}" in
                start)  watcher_start ;;
                stop)   watcher_stop ;;
                status) watcher_status ;;
                *)      echo "Usage: hyprcaffeine watcher <start|stop|status>" >&2; exit 1 ;;
            esac
            ;;
        tui|dashboard)
            # Launch Premium TUI (ratatui)
            local tui_bin="${HOME}/.local/bin/hyprcaffeine-tui"
            if [[ -x "${tui_bin}" ]]; then
                exec "${tui_bin}" "$@"
            else
                echo "TUI not installed. Build with: cd src-tui && cargo build --release" >&2
                exit 1
            fi
            ;;
        "")
            # No args — interactive gum menu
            if command -v gum &>/dev/null; then
                bash "${LIB_DIR}/caffeine-menu.sh"
            else
                show_help
            fi
            ;;
        *)
            echo "Unknown command: ${subcommand}" >&2
            echo "Run 'hyprcaffeine --help' for usage." >&2
            exit 1
            ;;
    esac
}

main "$@"
